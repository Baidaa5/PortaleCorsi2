<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
	https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
	
	<persistence-unit name="PortaleCorsiDAO" transaction-type="RESOURCE_LOCAL">	<!-- JNDI-->
	
		<non-jta-data-source>java:/MySqlDS</non-jta-data-source>		<!--stringa JNDI con "non" permette transazioni manuali  -->
		<class>model.entity.Utente</class>
	</persistence-unit>
 
</persistence>
 
 